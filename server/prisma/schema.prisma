generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  phoneNumber String
  password String
  role     String
  createdAt DateTime @default(now())
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  senderName     String
  content        String
  createdAt      DateTime @default(now())
}
